<Window x:Class="ProfanityFilterEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profanity Filter Editor" Height="1480" Width="1280"
        MinHeight="1160" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/Assets/icon.ico"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="132"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Background art at ~50% darkness (image + black overlay), behind everything -->
        <Image Grid.RowSpan="2" Source="/Assets/background.jpg" Stretch="UniformToFill"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Rectangle Grid.RowSpan="2" Fill="Black" Opacity="0.5"/>

        <!-- Header bar, like the launcher's top strip -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBarBrush}">
            <Grid Margin="40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="68" Height="68" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="32,0,0,0">
                    <Grid>
                        <TextBlock Text="PROFANITY FILTER" FontFamily="{StaticResource DisplayFont}" FontSize="40"
                                   Foreground="{StaticResource TextShadowBrush}" Margin="4,4,0,0"/>
                        <TextBlock Text="PROFANITY FILTER" FontFamily="{StaticResource DisplayFont}" FontSize="40"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                    <TextBlock Text="BEDROCK EDITION - LOCAL EDITOR" FontFamily="{StaticResource UiFont}" FontSize="20"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="CHANGE INSTALL" Style="{StaticResource StoneButton}"
                        VerticalAlignment="Center" Click="ChangeInstance_Click"/>
            </Grid>
        </Border>

        <!-- Main panel -->
        <Grid Grid.Row="1" Margin="48,40,48,44">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Install path -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <TextBlock Text="INSTALL" FontFamily="{StaticResource UiFont}" FontSize="20"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock x:Name="InstancePathText" Text="No Minecraft install selected"
                           FontFamily="{StaticResource DataFont}" FontSize="24"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Filter enable/disable: moves the untouched file between data\ (active) and
                 the install root (inactive), so Minecraft can't find it without editing it. -->
            <Grid Grid.Row="1" Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="FILTER STATUS" FontFamily="{StaticResource UiFont}" FontSize="20"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="FilterStateText" Text="Unknown" FontFamily="{StaticResource DataFont}"
                               FontSize="24" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="ToggleFilterButton" Content="N/A"
                        Style="{StaticResource StoneButton}" Width="220" Height="68"
                        VerticalAlignment="Center" IsEnabled="False"
                        Click="ToggleFilter_Click"/>
            </Grid>

            <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,0,0,28"
                       FontFamily="{StaticResource UiFontRegular}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="24" TextWrapping="Wrap"/>

            <!-- Add word row -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="NewWordBox" KeyDown="NewWordBox_KeyDown" TextChanged="NewWordBox_TextChanged"/>
                    <TextBlock x:Name="NewWordPlaceholder" Text="add a word to the blocklist"
                               FontFamily="{StaticResource DataFont}" FontSize="28"
                               Foreground="{StaticResource TextMutedBrush}" Margin="20,0,0,0"
                               IsHitTestVisible="False" VerticalAlignment="Center"/>
                </Grid>
                <Button Grid.Column="2" Content="ADD" Style="{StaticResource StoneButton}" Width="160" Click="AddWord_Click"/>
            </Grid>

            <!-- Search row -->
            <Grid Grid.Row="4" Margin="0,0,0,24">
                <TextBox x:Name="SearchBox" FontSize="24" TextChanged="SearchBox_TextChanged"/>
                <TextBlock x:Name="SearchPlaceholder" Text="search blocklist..."
                           FontFamily="{StaticResource DataFont}" FontSize="24"
                           Foreground="{StaticResource TextMutedBrush}" Margin="20,0,0,0"
                           IsHitTestVisible="False" VerticalAlignment="Center"/>
            </Grid>

            <!-- Inset console-style list panel -->
            <Border Grid.Row="5" Background="{StaticResource PanelInsetBrush}" Padding="12">
                <Grid>
                    <Rectangle Height="4" VerticalAlignment="Top" Fill="#88000000"/>
                    <Rectangle Width="4" HorizontalAlignment="Left" Fill="#88000000"/>
                    <Rectangle Height="4" VerticalAlignment="Bottom" Fill="#22FFFFFF"/>
                    <Rectangle Width="4" HorizontalAlignment="Right" Fill="#22FFFFFF"/>
                    <ListBox x:Name="WordListBox" Margin="8" BorderThickness="0" Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#3A3A3A" BorderThickness="0,0,0,2" Padding="20,18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontFamily="{StaticResource DataFont}"
                                                   FontSize="28" Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="X" Style="{StaticResource DenyButton}"
                                                Click="RemoveWord_Click" Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="6" Margin="0,32,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="CountText" Grid.Row="0" Margin="0,0,0,20"
                           FontFamily="{StaticResource DataFont}" FontSize="24"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <Button Grid.Row="1" x:Name="SaveButton" Content="SAVE CHANGES"
                        Style="{StaticResource PlayButton}" HorizontalAlignment="Stretch" Click="Save_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
