<Window x:Class="ProfanityFilterEditor.SelectInstanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose a Minecraft Install"
        Width="1160" Height="880"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="116"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Grid.RowSpan="2" Source="/Assets/background.jpg" Stretch="UniformToFill"/>
        <Rectangle Grid.RowSpan="2" Fill="Black" Opacity="0.5"/>

        <Border Grid.Row="0" Background="{StaticResource HeaderBarBrush}">
            <Grid Margin="40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="56" Height="56" VerticalAlignment="Center" Margin="0,0,28,0">
                    <Image Source="/Assets/logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>
                <Grid Grid.Column="1">
                    <TextBlock Text="MULTIPLE INSTALLS FOUND" FontFamily="{StaticResource DisplayFont}" FontSize="32"
                               Foreground="{StaticResource TextShadowBrush}" Margin="4,4,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MULTIPLE INSTALLS FOUND" FontFamily="{StaticResource DisplayFont}" FontSize="32"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="48,36,48,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Pick which Minecraft install to edit the blocklist for."
                       Foreground="{StaticResource TextMutedBrush}" FontSize="24" Margin="0,0,0,28" TextWrapping="Wrap"/>

            <Border Grid.Row="1" Background="{StaticResource PanelInsetBrush}" Padding="12">
                <Grid>
                    <Rectangle Height="4" VerticalAlignment="Top" Fill="#88000000"/>
                    <Rectangle Width="4" HorizontalAlignment="Left" Fill="#88000000"/>
                    <Rectangle Height="4" VerticalAlignment="Bottom" Fill="#22FFFFFF"/>
                    <Rectangle Width="4" HorizontalAlignment="Right" Fill="#22FFFFFF"/>
                    <ListBox x:Name="InstanceList" Margin="8" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#3A3A3A" BorderThickness="0,0,0,2" Padding="20,24">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PackageFolderName}" FontFamily="{StaticResource DataFont}"
                                                   FontWeight="Bold" FontSize="26" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding InstallPath}" Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource DataFont}" FontSize="22" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="CANCEL" Style="{StaticResource StoneButton}" Width="200" Margin="0,0,20,0" Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="USE THIS" Style="{StaticResource PlayButton}" Width="280" Click="Confirm_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
