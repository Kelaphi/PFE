<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Concept: the classic pre-2017 Mojang launcher - dark stone-grey panels,
        chunky beveled "pixel" buttons (light edge top-left, dark edge
        bottom-right, like Minecraft's own 9-slice GUI buttons), a big green
        button for the primary action, and an inset dark console-style list.
    -->

    <!-- Palette (panel brushes carry alpha now, so the background art shows through them) -->
    <SolidColorBrush x:Key="StoneDarkBrush" Color="#D9313233"/>
    <SolidColorBrush x:Key="StoneMidBrush" Color="#8B8B8B"/>
    <SolidColorBrush x:Key="StoneLightBrush" Color="#C6C6C6"/>
    <SolidColorBrush x:Key="HeaderBarBrush" Color="#E01E1E1E"/>
    <SolidColorBrush x:Key="PanelInsetBrush" Color="#EC232323"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="PlayGreenBrush" Color="#3C8527"/>
    <SolidColorBrush x:Key="DangerStoneBrush" Color="#7A4B44"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E4E4E4"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TextShadowBrush" Color="#161616"/>
    <SolidColorBrush x:Key="HoverTextBrush" Color="#FFFFA0"/>

    <!--
        Type is Minecraft Seven, a pixel font styled after the game's UI typeface.
        The actual Minecraft/"Mojangles" font itself is proprietary and isn't included.
    -->
    <FontFamily x:Key="DisplayFont">pack://application:,,,/Fonts/seven.ttf#Minecraft Seven</FontFamily>
    <FontFamily x:Key="UiFont">pack://application:,,,/Fonts/seven.ttf#Minecraft Seven</FontFamily>
    <FontFamily x:Key="UiFontRegular">pack://application:,,,/Fonts/seven.ttf#Minecraft Seven</FontFamily>
    <FontFamily x:Key="DataFont">pack://application:,,,/Fonts/seven.ttf#Minecraft Seven</FontFamily>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource StoneDarkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFontRegular}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Shared pixel-bevel button chrome: light edge top/left, dark edge bottom/right,
         a hover tint + yellow text (the classic Minecraft button hover), and a
         slight "press" shift so it reads as a physical block being pushed in. -->
    <ControlTemplate x:Key="PixelButtonTemplate" TargetType="Button">
        <Grid>
            <Border x:Name="face" Background="{TemplateBinding Background}"/>
            <Rectangle Height="4" VerticalAlignment="Top" Fill="#66FFFFFF"/>
            <Rectangle Width="4" HorizontalAlignment="Left" Fill="#66FFFFFF"/>
            <Rectangle Height="4" VerticalAlignment="Bottom" Fill="#77000000"/>
            <Rectangle Width="4" HorizontalAlignment="Right" Fill="#77000000"/>
            <Border x:Name="hover" Background="#2AFFFFFF" Opacity="0"/>
            <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="hover" Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource HoverTextBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="content" Property="Margin" Value="6,8,2,0"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="face" Property="Opacity" Value="0.5"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Big green primary action button (the "PLAY" button) -->
    <Style x:Key="PlayButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PlayGreenBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="Padding" Value="36,24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template" Value="{StaticResource PixelButtonTemplate}"/>
    </Style>

    <!-- Grey stone button for secondary actions -->
    <Style x:Key="StoneButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource StoneMidBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Padding" Value="24,16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template" Value="{StaticResource PixelButtonTemplate}"/>
    </Style>

    <!-- Reddish stone button used for the "disable" action -->
    <Style x:Key="WarnButton" TargetType="Button" BasedOn="{StaticResource StoneButton}">
        <Setter Property="Background" Value="{StaticResource DangerStoneBrush}"/>
    </Style>

    <!-- Small square "remove" stone button with a reddish tint -->
    <Style x:Key="DenyButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DangerStoneBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DataFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template" Value="{StaticResource PixelButtonTemplate}"/>
    </Style>

    <!-- Inset "pressed in" text field, like the classic username/version boxes -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PanelInsetBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DataFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"/>
                        <Rectangle Height="4" VerticalAlignment="Top" Fill="#88000000"/>
                        <Rectangle Width="4" HorizontalAlignment="Left" Fill="#88000000"/>
                        <Rectangle Height="4" VerticalAlignment="Bottom" Fill="#33FFFFFF"/>
                        <Rectangle Width="4" HorizontalAlignment="Right" Fill="#33FFFFFF"/>
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Background" Value="{StaticResource PanelInsetBrush}"/>
    </Style>

</ResourceDictionary>
